generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum Role {
    ADMIN
    USER
}

enum LogisyncRole {
    ADMIN_SUPER
    ANALYST
}

enum OrderStatus {
    PENDING
    CREATED
    SHIPPED
    DELIVERY_ATTEMPT
    DELIVERED
    FAILURE
    RETURNED
    CANCELED
    CHANNEL_LOGISTICS
}

model User {
    id       String @id @default(uuid())
    email    String @unique
    name     String
    password String // bcrypt hash
    role     Role   @default(USER)
    userGlobalId String? @unique(map: "User_userGlobalId_unique")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    companyId String?
    company   Company? @relation(fields: [companyId], references: [id])

    orders       Order[]           @relation("UserOrders")
    accessTokens UserAccessToken[]
    releaseNotes ReleaseNote[]
    monitoredOrders MonitoredOrder[]
    customOrderStatuses CompanyOrderCustomStatus[]
}

model UserAccessToken {
    id        String   @id @default(uuid())
    tokenHash String   @unique
    type      String
    expiresAt DateTime
    usedAt    DateTime?
    createdAt DateTime @default(now())

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, type])
    @@index([expiresAt])
}

model Company {
    id          String   @id @default(uuid())
    name        String
    cnpj        String?
    tenantGlobalId String? @unique(map: "Company_tenantGlobalId_unique")
    documentType String? // CNPJ | CPF
    documentNumber String? // somente digitos
    trayIntegrationEnabled Boolean @default(true)
    anymarketIntegrationEnabled Boolean @default(false)
    blingIntegrationEnabled Boolean @default(false)
    magazordIntegrationEnabled Boolean @default(false)
    sysempIntegrationEnabled Boolean @default(false)
    intelipostIntegrationEnabled Boolean @default(true)
    sswRequireEnabled Boolean @default(true)
    correiosIntegrationEnabled Boolean @default(true)
    databaseUrl String? // URL do banco de dados especÃ­fico da empresa
    intelipostClientId String?
    anymarketApiBaseUrl String?
    anymarketPlatform String?
    anymarketToken String? @db.Text
    magazordApiBaseUrl String?
    magazordApiUser String?
    magazordApiPassword String? @db.Text
    sswRequireCnpjs String[] @default([])
    integrationCarrierExceptions String[] @default([])
    createdAt   DateTime @default(now())
    users       User[]
    orders      Order[]
    trayAuth    TrayAuth?
    trayCheckoutQuotes TrayCheckoutQuote[]
    monitoredOrders MonitoredOrder[]
    syncNotifications SyncNotification[]
    customOrderStatuses CompanyOrderCustomStatus[]
    logisyncUsers LogisyncUser[]

    @@index([documentType, documentNumber], map: "Company_document_idx")
}

model ReleaseNote {
    id             String   @id @default(uuid())
    version        String
    title          String
    summary        String
    newFeatures    String[] @default([])
    adjustments    String[] @default([])
    htmlContent    String
    recipientCount Int      @default(0)
    createdAt      DateTime @default(now())

    sentByUserId String?
    sentByUser   User?   @relation(fields: [sentByUserId], references: [id])

    @@index([createdAt])
}

model Carrier {
    id      String  @id @default(uuid())
    name    String  @unique
    apiType String // SSW, Correios, MelhorEnvio etc
    active  Boolean @default(true)

    createdAt DateTime @default(now())

    orders Order[]
}

model Order {
    id String @id @default(uuid())

    // IdentificaÃ§Ã£o
    orderNumber   String
    invoiceNumber String? // NF
    trackingCode  String? // CÃ³digo de rastreio

    // Cliente
    customerName  String
    corporateName String?
    cpf           String?
    cnpj          String?
    phone         String?
    mobile        String?

    // Canal / LogÃ­stica
    salesChannel         String
    freightType          String?
    freightValue         Float? // Frete pago original
    quotedFreightValue   Float? // Frete cotado pela API
    quotedFreightDate    DateTime? // Data da Ãºltima cotaÃ§Ã£o
    quotedFreightDetails Json? // Detalhes da cotaÃ§Ã£o (JSON com todas as opÃ§Ãµes)
    originalQuotedFreightValue Float? // Cotacao original salva no checkout/gateway
    originalQuotedFreightDate DateTime? // Data da cotacao original do checkout
    originalQuotedFreightDetails Json? // Snapshot da cotacao original
    originalQuotedFreightQuotationId String? // quotation_id da Tray
    recalculatedFreightValue Float? // Cotacao recalculada depois do pedido
    recalculatedFreightDate DateTime? // Data do recalculo mais recente
    recalculatedFreightDetails Json? // Snapshot do recalculo atual

    shippingDate DateTime?

    carrierId String?
    carrier   Carrier? @relation(fields: [carrierId], references: [id])

    // EndereÃ§o
    address      String
    number       String
    complement   String?
    neighborhood String
    city         String
    state        String
    zipCode      String

    // Financeiro
    totalValue Float

    // Prazos
    recipient             String?
    maxShippingDeadline   DateTime?
    estimatedDeliveryDate DateTime?
    carrierEstimatedDeliveryDate DateTime?

    // Estado Atual
    status    OrderStatus @default(PENDING)
    isDelayed Boolean     @default(false)
    isArchived Boolean @default(false)
    archivedAt DateTime?
    manualCustomStatus String?
    observation String?

    lastApiSync DateTime?
    lastUpdate  DateTime  @updatedAt

    // Controle de erro de rastreio
    lastApiError  String?
    apiRawPayload Json?

    // Auditoria
    createdAt DateTime @default(now())

    // RelaÃ§Ãµes
    trackingEvents TrackingEvent[]
    createdById    String?
    createdBy      User?           @relation("UserOrders", fields: [createdById], references: [id])
    monitoredOrders MonitoredOrder[]

    companyId String?
    company   Company? @relation(fields: [companyId], references: [id])

    @@index([status])
    @@index([orderNumber])
    @@index([invoiceNumber])
    @@index([trackingCode])
    @@index([isDelayed])
    @@index([lastApiSync])
    @@index([originalQuotedFreightQuotationId])
    @@index([isArchived, companyId], map: "Order_archived_company_idx")
}

model LogisyncUser {
    id           String      @id @default(uuid())
    email        String      @unique
    name         String
    password     String // bcrypt hash
    role         LogisyncRole @default(ANALYST)
    isActive     Boolean     @default(true)
    companyId    String?
    company      Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
    createdAt    DateTime    @default(now())
    updatedAt    DateTime    @updatedAt

    @@index([companyId])
}

model MonitoredOrder {
    id String @id @default(uuid())

    companyId String
    company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

    orderId String
    order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

    createdById String?
    createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)
    watchEvents String[] @default([])

    createdAt DateTime @default(now())

    @@unique([companyId, orderId], map: "MonitoredOrder_companyId_orderId_key")
    @@index([companyId, createdAt], map: "MonitoredOrder_company_created_idx")
}

model SyncNotification {
    id String @id @default(uuid())

    companyId String
    company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

    category String
    type String
    title String
    message String
    payload Json?
    readAt DateTime?

    createdAt DateTime @default(now())

    @@index([companyId, createdAt], map: "SyncNotification_company_created_idx")
    @@index([companyId, category, createdAt], map: "SyncNotification_company_category_created_idx")
    @@index([companyId, readAt, createdAt], map: "SyncNotification_company_read_created_idx")
}

model CompanyOrderCustomStatus {
    id String @id @default(uuid())

    companyId String
    company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

    label String

    createdById String?
    createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([companyId, label], map: "CompanyOrderCustomStatus_companyId_label_key")
    @@index([companyId, createdAt], map: "CompanyOrderCustomStatus_company_created_idx")
}

model TrayCheckoutQuote {
    id String @id @default(uuid())

    companyIdValue String?
    company Company? @relation(fields: [companyIdValue], references: [id], onDelete: Cascade)

    trayStoreId String?
    token String?
    sessionId String?
    originZipCode String?
    destinationZipCode String?
    productsRaw Json?
    productsHash String?

    quotationId String @unique
    shippingId String?
    shipmentType String?
    serviceCode String?
    serviceName String?
    integrator String?
    quotedValue Float?
    minPeriod Int?
    maxPeriod Int?
    selectedPossible Boolean?
    snapshotData Json?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([companyIdValue])
    @@index([trayStoreId])
    @@index([sessionId])
    @@index([productsHash])
}

model TrackingEvent {
    id String @id @default(uuid())

    orderId String
    order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

    status      String
    description String
    city        String?
    state       String?

    eventDate DateTime
    createdAt DateTime @default(now())

    @@index([orderId])
    @@index([eventDate])
}

model TrayAuth {
    id           String   @id @default(uuid())
    storeId      String
    storeName    String?
    apiAddress   String
    accessToken  String   @db.Text
    refreshToken String?  @db.Text
    code         String?  @db.Text
    expiresAt    DateTime
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    companyId String?  @unique
    company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

    @@index([storeId])
}

